# Биржа 1 (например, Binance)
EXCHANGE1_API_KEY=your_api_key_here
EXCHANGE1_API_SECRET=your_api_secret_here
EXCHANGE1_NAME=binance

# Биржа 2 (например, Bybit)
EXCHANGE2_API_KEY=your_api_key_here
EXCHANGE2_API_SECRET=your_api_secret_here
EXCHANGE2_NAME=bybit

# Параметры торговли
TRADE_SIZE_USDT=100
MIN_SPREAD_PCT=0.3
MAX_POSITION_PCT=10

# Логирование
LOG_LEVEL=INFO

# Режим работы (true = симуляция, false = реальная торговля)
DRY_RUN=true

# Telegram-уведомления (опционально)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
